# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@railway-host:5432/dbname
SCRAPER_SERVICE_SECRET=change-this-to-a-strong-random-secret

# ── Playwright ────────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
COURT_PLAYWRIGHT_STATUS_URL=https://hckinfo.keralacourts.in/digicourt/...
COURT_PLAYWRIGHT_SEARCH_URL=https://hckinfo.keralacourts.in/digicourt/...
COURT_PLAYWRIGHT_VIEW_URL=https://hckinfo.keralacourts.in/digicourt/...

# ── AWS (for S3 — daily cause list PDFs) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
CAUSELIST_S3_BUCKET_NAME=lawmate-khc-prod
CAUSELIST_S3_PREFIX=causelist
ROSTER_S3_BUCKET_NAME=lawmate-khc-prod
ROSTER_S3_PREFIX=roster
CAUSELIST_DAILY_URL=https://hckinfo.keralacourts.in/digicourt/Casedetailssearch/viewCauselist
ROSTER_SOURCE_URL=https://highcourt.kerala.gov.in/

# ── AI (Bedrock/Anthropic — used by case enrichment) ─────────────────────────
AWS_BEDROCK_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
ANTHROPIC_API_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=same-as-main-backend
S3_BUCKET_NAME=lawmate-case-pdfs
